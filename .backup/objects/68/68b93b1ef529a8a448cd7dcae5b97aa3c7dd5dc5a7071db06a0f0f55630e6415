import 'package:flutter/material.dart';
import 'package:flutter/services.dart';

void main() => runApp(const ServerApp());

class ServerApp extends StatelessWidget {
  const ServerApp({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: 'MC Server',
      theme: ThemeData(
        colorSchemeSeed: Colors.green,
        useMaterial3: true,
        brightness: Brightness.dark,
      ),
      home: const ServerPage(),
    );
  }
}

class ServerPage extends StatefulWidget {
  const ServerPage({super.key});

  @override
  State<ServerPage> createState() => _ServerPageState();
}

class _ServerPageState extends State<ServerPage> {
  static const _channel = MethodChannel('apptest/server');
  String _status = 'Tap Install JRE to begin';
  String _log = '';
  bool _jreReady = false;

  Future<void> _installJre() async {
    setState(() => _status = 'Downloading & installing JRE (~50MB)…');
    try {
      await _channel.invokeMethod<String>('installJre');
      setState(() => _jreReady = true);
      _status = 'JRE ready — put server.jar in minecraft/ then Start';
    } on PlatformException catch (e) {
      setState(() => _status = 'Error: ${e.message}');
    }
  }

  Future<void> _start() async {
    setState(() => _status = 'Starting server…');
    try {
      await _channel.invokeMethod('startServer', {'args': <String>['nogui']});
      _status = 'Running';
      _pollLog();
    } on PlatformException catch (e) {
      setState(() => _status = 'Error: ${e.message}');
    }
  }

  Future<void> _stop() async {
    await _channel.invokeMethod('stopServer');
    setState(() => _status = 'Stopped');
  }

  void _pollLog() async {
    while (mounted) {
      final log = await _channel.invokeMethod<String>('getLog');
      if (log == null || log.isEmpty) break;
      setState(() => _log = log);
      await Future.delayed(const Duration(seconds: 1));
    }
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: const Text('Minecraft Server'), centerTitle: true),
      body: Padding(
        padding: const EdgeInsets.all(16),
        child: Column(
          children: [
            Text(_status, style: Theme.of(context).textTheme.titleMedium),
            const SizedBox(height: 16),
            Row(
              mainAxisAlignment: MainAxisAlignment.center,
              children: [
                FilledButton.icon(
                  onPressed: _jreReady ? null : _installJre,
                  icon: const Icon(Icons.download),
                  label: const Text('Install JRE'),
                ),
                const SizedBox(width: 12),
                FilledButton.icon(
                  onPressed: _jreReady ? _start : null,
                  icon: const Icon(Icons.play_arrow),
                  label: const Text('Start'),
                ),
                const SizedBox(width: 12),
                OutlinedButton.icon(
                  onPressed: _stop,
                  icon: const Icon(Icons.stop),
                  label: const Text('Stop'),
                ),
              ],
            ),
            const SizedBox(height: 24),
            Expanded(
              child: Container(
                width: double.infinity,
                padding: const EdgeInsets.all(8),
                decoration: BoxDecoration(
                  color: Colors.black87,
                  borderRadius: BorderRadius.circular(8),
                ),
                child: SingleChildScrollView(
                  child: Text(
                    _log.isEmpty ? 'Server output will appear here…' : _log,
                    style: const TextStyle(
                      fontFamily: 'monospace',
                      color: Colors.greenAccent,
                      fontSize: 12,
                    ),
                  ),
                ),
              ),
            ),
          ],
        ),
      ),
    );
  }
}
